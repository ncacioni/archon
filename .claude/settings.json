{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ./)",
      "Bash(find * -delete*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- .)",
      "Bash(git checkout -- *)",
      "Bash(git branch -D*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(curl * | zsh*)",
      "Bash(curl * | python*)",
      "Bash(curl * | node*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(chmod 777*)",
      "Bash(chmod -R 777*)"
    ]
  }
}
