{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "security-approval",
  "description": "Handoff from security to builder: security review result with approval or veto",
  "type": "object",
  "required": ["approved", "reviewed_at", "spec_file", "findings"],
  "properties": {
    "approved": {
      "type": "boolean",
      "description": "Whether the spec/design is approved to proceed to implementation"
    },
    "veto": {
      "type": "boolean",
      "description": "True if security has hard-blocked implementation (critical finding)"
    },
    "reviewed_at": {
      "type": "string",
      "description": "ISO 8601 datetime"
    },
    "spec_file": {
      "type": "string",
      "description": "Path to the spec file that was reviewed"
    },
    "findings": {
      "type": "object",
      "required": ["blockers", "high", "medium", "low"],
      "properties": {
        "blockers": {
          "type": "array",
          "items": { "$ref": "#/definitions/finding" }
        },
        "high": {
          "type": "array",
          "items": { "$ref": "#/definitions/finding" }
        },
        "medium": {
          "type": "array",
          "items": { "$ref": "#/definitions/finding" }
        },
        "low": {
          "type": "array",
          "items": { "$ref": "#/definitions/finding" }
        }
      },
      "additionalProperties": false
    },
    "conditions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Conditions that must be met before shipping (non-blocking but required)"
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suggestions for implementation (advisory, not required)"
    }
  },
  "definitions": {
    "finding": {
      "type": "object",
      "required": ["id", "description", "category"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "file": { "type": "string" },
        "line": { "type": "integer" },
        "fix": { "type": "string" },
        "owasp": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
